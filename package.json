  "homepage": "https://github.com/rozek/javascript-interface-library#readme",
  "devDependencies": {
    "agadoo": "^3.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.1.0"
  }
